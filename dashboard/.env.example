# Google Sheets credentials for live Trading data.
# If any of GOOGLE_CREDENTIALS / GOOGLE_SHEET_ID / SHEET_NAME / BROKER_ACCOUNTS_JSON is missing,
# /api/trading silently falls back to the deterministic mock generator (lib/mocks/trading.ts).

# Base64-encoded service-account JSON (the same value the pipeline uses).
GOOGLE_CREDENTIALS=eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsIC4uLn0=

# Spreadsheet ID from the sheet URL.
GOOGLE_SHEET_ID=1AbcDefGhiJkLmnOpQrStUvWxYz0123456789

# Numeric GID of the target tab (Sheet URL fragment #gid=...).
SHEET_GID=0

# Tab (sheet) name as it appears in the spreadsheet.
SHEET_NAME=Trade Book

# Mailbox + accounts config (same shape the pipeline consumes).
# Each account contributes a 5-column block to the sheet starting at `sheetStartColumn`.
BROKER_ACCOUNTS_JSON=[{"email":"user@gmail.com","emailPassword":"xxx","accounts":[{"broker":"finvasia","accountId":"FA1234","pdfPassword":"xxx","sheetStartColumn":"D"},{"broker":"angelone","accountId":"R59799620","pdfPassword":"xxx","sheetStartColumn":"I"}]}]
